# Скопируйте в .env.local и заполните своими значениями.
# Все переменные необязательны — без них сайт работает, но соответствующая
# функция просто отключается.

# ── Уведомления о заявках ──
# Telegram-бот: создайте бота через @BotFather, получите токен.
# CHAT_ID — id чата/группы, куда слать заявки (узнать через @userinfobot).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Альтернатива/дополнение: произвольный webhook (CRM, Make, n8n и т.п.),
# куда POST-ом уйдёт JSON заявки.
BOOKING_WEBHOOK_URL=

# ── Аналитика ──
# Номер счётчика Яндекс.Метрики. Грузится ТОЛЬКО после согласия на cookies.
# Должен начинаться с NEXT_PUBLIC_, чтобы быть доступным в браузере.
NEXT_PUBLIC_YM_ID=

# ── База данных (PostgreSQL / Neon) ──
# При установке Neon через Vercel Marketplace переменная провижнится автоматически
# (обычно DATABASE_URL или POSTGRES_URL).
# Миграции и начальный сид выполняются автоматически при каждом деплое (scripts/setup-db.ts).
# Для локальной разработки: vercel env pull .env.local
DATABASE_URL=
POSTGRES_URL=

# ── Админка (/admin) ──
# Учётные записи админов с ролями хранятся в БД (таблица admins).
# При первом входе, если таблица пуста, автоматически создаётся владелец
# с логином ADMIN_LOGIN и паролем ADMIN_PASSWORD (роль owner).
# Логин первого владельца (по умолчанию "admin").
ADMIN_LOGIN=admin
# Пароль владельца при первичной настройке. Без БД используется как единый
# пароль входа. Без него вход недоступен.
ADMIN_PASSWORD=
# Секрет для подписи cookie-сессии. Сгенерируйте случайную строку, например:
#   openssl rand -base64 32
# Если не задан — используется ADMIN_PASSWORD (менее безопасно).
ADMIN_SESSION_SECRET=

# ── Личный кабинет клиента (/cabinet) ──
# Отправка кодов входа по СМС через SMS.ru. Получите api_id в личном кабинете sms.ru.
# Без него код входа НЕ отправляется по СМС, а пишется в серверный лог и (если
# настроен Telegram-бот выше) дублируется администратору — только для теста/настройки.
SMS_RU_API_ID=
# Секрет для подписи cookie кабинета. Если не задан — используется
# ADMIN_SESSION_SECRET, затем ADMIN_PASSWORD.
CLIENT_SESSION_SECRET=
